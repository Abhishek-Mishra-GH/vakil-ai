# Database
DATABASE_URL=postgresql://legalai:legalai@localhost:5432/legalai
AUTO_APPLY_SCHEMA=true

# App
APP_NAME=VakilAI API
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth
JWT_SECRET_KEY=myveryrverystrongjwtsecretkey
JWT_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_QA_MODEL=gpt-4.1-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Cohere
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# AWS Textract
# Used for OCR on scanned/image PDFs. For text PDFs, pipeline can fallback to pypdf.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Cloudinary
# Optional. If empty, backend stores uploads under LOCAL_UPLOAD_DIR.
CLOUDINARY_URL=
LOCAL_UPLOAD_DIR=../data/uploads

# Indian Kanoon
INDIAN_KANOON_API_KEY=

# Pipeline tuning
OCR_CONFIDENCE_THRESHOLD=60
MIN_CHUNK_CHARS=80
MAX_UPLOAD_SIZE_MB=50
STATUTES_PATH=../data/statutes.json
